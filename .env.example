# Runtime environment variables used by docker-compose.yml and injected at container start.

# Your self-hosted VoceChat instance URL (no trailing slash)
VOCECHAT_HOST=https://chat.gnomguttan.no

# App display title
APP_TITLE=Gnomguttan

# VoceChat bot announcement channel/group ID for the info bot
VOCECHAT_BOT_TARGET_GROUP_ID=

# VoceChat bot API key used by the container-side proxy
# Keep this on the server side only; it is not exposed to the browser.
VOCECHAT_BOT_API_KEY=

# Jellyfin server URL for Hubert Cinema metadata/API access
# Use the direct Jellyfin server address here, not the client URL.
JELLYFIN_HOST=https://tv.jensmartin.no

# Jellyfin client URL used when opening movie/series pages
JELLYFIN_CLIENT_URL=https://kino.gnomguttan.no

# Jellyfin API key used by the runtime proxy
JELLYFIN_TOKEN=
