# Runtime environment variables used by docker-compose.yml and injected at container start.

# MongoDB connection string used by the app server.
# In local development this can be omitted and the server will start a temporary in-memory database.
# This is usually an external MongoDB URI with username/password, for example:
# mongodb://username:password@host:27017/gnomguttan?authSource=admin
# or mongodb+srv://username:password@cluster.example.mongodb.net/gnomguttan?retryWrites=true&w=majority
MONGODB_URI=mongodb://username:password@host:27017/gnomguttan?authSource=admin

# MongoDB database name. If omitted, the database name is read from the URI path or falls back to gnomguttan.
MONGODB_DB=

# Optional override for local Vite dev proxying to the app API
APP_API_TARGET=http://localhost:3001

# Port used by the Node server
PORT=3001

# Your self-hosted VoceChat instance URL (no trailing slash)
VOCECHAT_HOST=https://chat.gnomguttan.no

# App display title
APP_TITLE=Gnomguttan

# VoceChat bot announcement channel/group ID for the info bot
VOCECHAT_BOT_TARGET_GROUP_ID=

# VoceChat bot API key used by the container-side proxy
# Keep this on the server side only; it is not exposed to the browser.
VOCECHAT_BOT_API_KEY=

# Jellyfin server URL for Hubert Cinema metadata/API access
# Use the direct Jellyfin server address here, not the client URL.
JELLYFIN_HOST=https://tv.jensmartin.no

# Jellyfin client URL used when opening movie/series pages
JELLYFIN_CLIENT_URL=https://kino.gnomguttan.no

# Jellyfin API key used by the runtime proxy
JELLYFIN_TOKEN=
