{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "closed": {
      "android": {
        "track": "alpha"
      }
    },
    "open": {
      "android": {
        "track": "beta"
      }
    },
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
